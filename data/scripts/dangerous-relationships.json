{
  "name": "危险关系模拟器",
  "description": "情感拉扯、谎言压力、道德挣扎、修罗场。玩家在已有伴侣的情况下面对新情感诱惑，每个选择都影响未来走向。",
  "rules": {
    "writing_style": "文风像豆瓣/网络高热恋爱文。生活真实语气。直白描写，禁止文艺比喻过多。禁止油腻霸总感、老土剧情。当前阶段：{{stage}}。",
    "forbidden": [
      "禁止开局直接上床，哪怕捡尸也要有简短过程",
      "禁止见面三天爱得死去活来",
      "所有关系必须循序渐进",
      "禁止AI解释剧情或跳出角色",
      "禁止描写简短/一句话结束",
      "角色拥有独立生活、独立情绪和独立判断，不会围绕玩家转",
      "禁止{{partner}}和{{target}}同时出场时一方完全沉默"
    ],
    "requirements": [
      "长描写、沉浸式互动",
      "每轮必须给选择（自由输入或选项）",
      "允许吃醋、修罗场、冷战等剧情",
      "情感必须有铺垫",
      "涉及{{partner}}时重点描写其情绪变化和细节动作",
      "涉及{{target}}时重点描写暧昧氛围和边界感"
    ]
  },
  "dimensions": [
    { "id": "love", "name": "爱意值", "scope": "对{{partner}}", "range": [0, 100], "initial": [85, 95] },
    { "id": "trust", "name": "信任值", "scope": "对{{partner}}", "range": [0, 100], "initial": [85, 95] },
    { "id": "suspicion", "name": "怀疑值", "scope": "{{partner}}对{{player}}", "range": [0, 100], "initial": [0, 10] },
    { "id": "heartbeat", "name": "心动值", "scope": "对{{target}}", "range": [0, 100], "initial": [0, 0] },
    { "id": "desire", "name": "欲望值", "scope": "对{{target}}", "range": [0, 100], "initial": [0, 0] },
    { "id": "guilt", "name": "愧疚值", "scope": "{{player}}对{{partner}}", "range": [0, 100], "initial": [0, 0] },
    { "id": "stress", "name": "压力值", "scope": "{{player}}自身", "range": [0, 100], "initial": [0, 0] }
  ],
  "characters": [
    {
      "id": "player",
      "name": "玩家",
      "description": "由玩家自定义职业、性格等。当前与{{partner}}处于恋爱关系中，但遇到了{{target}}。"
    },
    {
      "id": "partner",
      "name": "现任",
      "description": "玩家当前的伴侣。温柔但敏感，对{{player}}的变化会默默观察。有自己的社交圈和生活习惯，不是恋爱脑。察觉异常时会旁敲侧击而非直接质问。"
    },
    {
      "id": "target",
      "name": "危险对象",
      "description": "新的情感诱惑。知道{{player}}有伴侣但仍然主动靠近。有自己的魅力和手段，不会显得廉价或刻意。会制造暧昧但不会太直白。"
    }
  ],
  "events": [
    {
      "name": "现任试探",
      "stage": 1,
      "trigger": { "suspicion": { "min": 30, "max": 50, "probability": 0.3 } },
      "description": "{{partner}}开始旁敲侧击，试探{{player}}的行踪和手机内容",
      "effects": {
        "sticky": { "dims": { "suspicion": 2 }, "duration": 3 },
        "cooldown": 4
      }
    },
    {
      "name": "现任偷看手机",
      "stage": 1,
      "trigger": { "suspicion": { "min": 50, "max": 70, "probability": 0.5 } },
      "description": "{{partner}}趁{{player}}不注意偷看了手机，发现了一些暧昧信息",
      "effects": {
        "sticky": { "dims": { "suspicion": 5, "trust": -3 }, "duration": 4 },
        "cooldown": 5
      }
    },
    {
      "name": "现任质问",
      "stage": 1,
      "trigger": { "suspicion": { "min": 70, "probability": 0.7 } },
      "description": "{{partner}}直接质问{{player}}最近的反常行为，情绪激动",
      "effects": {
        "sticky": { "dims": { "stress": 5, "love": -5 }, "duration": 3 },
        "cooldown": 6
      }
    },
    {
      "name": "危险对象示好",
      "stage": 1,
      "trigger": { "heartbeat": { "min": 20, "probability": 0.4 } },
      "description": "{{target}}主动示好，制造独处机会，{{player}}开始心动",
      "effects": {
        "sticky": { "dims": { "heartbeat": 3 }, "duration": 2 },
        "cooldown": 3
      }
    },
    {
      "name": "危险对象逼迫",
      "stage": 2,
      "trigger": { "desire": { "min": 60, "probability": 0.5 } },
      "description": "{{target}}察觉到{{player}}的欲望，主动逼迫{{player}}做出选择",
      "effects": {
        "sticky": { "dims": { "stress": 5 }, "duration": 3 },
        "cooldown": 5
      }
    },
    {
      "name": "玩家崩溃",
      "stage": 3,
      "trigger": {
        "op": "and",
        "conditions": [
          { "dim": "guilt", "min": 60 },
          { "dim": "stress", "min": 50 }
        ]
      },
      "description": "{{player}}因愧疚和压力出现失眠、做噩梦，精神状态急剧下降",
      "effects": {
        "sticky": { "dims": { "stress": 3, "guilt": 2 }, "duration": 4 },
        "cooldown": 5
      }
    },
    {
      "name": "修罗场",
      "stage": 3,
      "trigger": {
        "op": "and",
        "conditions": [
          { "dim": "suspicion", "min": 60 },
          { "dim": "heartbeat", "min": 50, "probability": 0.5 }
        ]
      },
      "description": "{{partner}}和{{target}}在同一场合出现，气氛剑拔弩张，三方对峙",
      "effects": {
        "sticky": { "dims": { "stress": 8, "suspicion": 5 }, "duration": 3 },
        "cooldown": 8
      }
    },
    {
      "name": "冷战开始",
      "stage": 2,
      "trigger": {
        "op": "and",
        "conditions": [
          { "dim": "suspicion", "min": 40 },
          { "dim": "trust", "max": 40 }
        ]
      },
      "description": "{{partner}}对{{player}}彻底失望，开始冷战，减少交流",
      "effects": {
        "sticky": { "dims": { "love": -5, "trust": -3 }, "duration": 5 },
        "cooldown": 6
      }
    }
  ],
  "stages": [
    { "name": "稳定生活", "transition": { "suspicion": { "min": 20 } } },
    { "name": "危险接触", "transition": { "heartbeat": { "min": 40 } } },
    { "name": "秘密关系", "transition": { "suspicion": { "min": 60 } } },
    { "name": "感情失控", "transition": { "guilt": { "min": 60 } } },
    { "name": "真相逼近", "transition": { "suspicion": { "min": 85 } } },
    { "name": "结局" }
  ],
  "endings": [
    {
      "name": "HE1-主动坦白",
      "condition": {
        "op": "and",
        "conditions": [
          { "dim": "guilt", "min": 70 },
          { "dim": "love", "min": 60 }
        ]
      },
      "description": "{{player}}鼓起勇气向{{partner}}坦白了一切，虽然过程痛苦，但真诚换来了理解和原谅。"
    },
    {
      "name": "HE2-断联回归",
      "condition": {
        "op": "and",
        "conditions": [
          { "dim": "love", "min": 70 },
          { "dim": "heartbeat", "max": 20 }
        ]
      },
      "description": "{{player}}主动断绝了和{{target}}的联系，全心回归{{partner}}身边，关系逐渐修复。"
    },
    {
      "name": "BE1-彻底翻车",
      "condition": { "suspicion": { "min": 90 } },
      "description": "所有真相大白，{{partner}}无法接受，关系彻底破裂。"
    },
    {
      "name": "BE2-双向出轨",
      "condition": {
        "op": "and",
        "conditions": [
          { "dim": "heartbeat", "min": 80 },
          { "dim": "guilt", "max": 20 }
        ]
      },
      "description": "{{player}}完全沉溺于和{{target}}的关系，对{{partner}}的愧疚消失殆尽。三个人的关系走向不可挽回的深渊。"
    },
    {
      "name": "NE-貌合神离",
      "condition": {
        "op": "and",
        "conditions": [
          { "dim": "suspicion", "min": 60 },
          { "dim": "love", "max": 30 },
          { "dim": "stress", "min": 50 }
        ]
      },
      "description": "{{player}}勉强维持着和{{partner}}的关系，但内心早已疲惫不堪。两个人住在一起，却像室友一样疏远。"
    },
    {
      "name": "OE-开放关系",
      "condition": {
        "op": "and",
        "conditions": [
          { "dim": "love", "min": 50 },
          { "dim": "heartbeat", "min": 50 },
          { "dim": "trust", "min": 40 }
        ]
      },
      "description": "{{player}}向{{partner}}坦白了对{{target}}的感情，经过激烈争吵和深入沟通后，三人达成了一种非传统的关系模式。不是所有人都能接受，但至少此刻每个人都是真诚的。"
    },
    {
      "name": "PE-三人家庭",
      "condition": {
        "op": "and",
        "conditions": [
          { "dim": "love", "min": 60 },
          { "dim": "heartbeat", "min": 60 },
          { "dim": "trust", "min": 60 },
          { "dim": "guilt", "max": 20 }
        ]
      },
      "description": "经过漫长的磨合，{{player}}、{{partner}}和{{target}}找到了共处的方式。三个人住在一起，分担家务、分享生活。外人不理解，但家里总是很热闹。{{partner}}学会了放手，{{target}}学会了等待，{{player}}学会了平衡。这不是童话，但这是他们的幸福。"
    }
  ],
  "setup": [
    {
      "step": "你的性别",
      "options": [
        { "label": "男", "value": "男" },
        { "label": "女", "value": "女" }
      ]
    },
    {
      "step": "你的性取向",
      "options": [
        { "label": "异性恋", "value": "异性恋" },
        { "label": "同性恋", "value": "同性恋" },
        { "label": "双性恋", "value": "双性恋" }
      ]
    },
    {
      "step": "你的职业",
      "options": [
        { "label": "普通上班族", "value": "普通上班族" },
        { "label": "设计师", "value": "设计师" },
        { "label": "律师", "value": "律师" },
        { "label": "医生", "value": "医生" },
        { "label": "摄影师", "value": "摄影师" },
        { "label": "咖啡店老板", "value": "咖啡店老板" }
      ],
      "allow_custom": true
    },
    {
      "step": "当前关系状态",
      "options": [
        { "label": "恋爱半年", "value": "恋爱半年" },
        { "label": "恋爱三年", "value": "恋爱三年" },
        { "label": "同居", "value": "同居" },
        { "label": "异地恋", "value": "异地恋" },
        { "label": "已婚", "value": "已婚" },
        { "label": "已婚有孩子", "value": "已婚有孩子" }
      ],
      "allow_custom": true
    },
    {
      "step": "危险对象身份",
      "options": [
        { "label": "新同事", "value": "新同事" },
        { "label": "上司", "value": "上司" },
        { "label": "前任", "value": "前任" },
        { "label": "健身教练", "value": "健身教练" },
        { "label": "旅行认识的人", "value": "旅行认识的人" },
        { "label": "朋友对象", "value": "朋友对象" }
      ],
      "allow_custom": true
    },
    {
      "step": "剧情风格",
      "options": [
        { "label": "现实慢热", "value": "现实慢热：数值变化缓慢，生活感强" },
        { "label": "禁忌感情", "value": "禁忌感情：道德压力极大" },
        { "label": "双向拉扯", "value": "双向拉扯：双方都主动又克制" },
        { "label": "高压偷情", "value": "高压偷情：风险高、刺激强" },
        { "label": "修罗场", "value": "修罗场：多线冲突频繁" }
      ]
    },
    {
      "step": "情欲浓度",
      "options": [
        { "label": "纯情感向", "value": "纯情感向：无色情，仅暗示" },
        { "label": "轻度情欲（推荐）", "value": "轻度情欲：感官暗示+氛围描写" },
        { "label": "中度情欲", "value": "中度情欲：详细动作+对话+内心独白" },
        { "label": "重度情欲", "value": "重度情欲：较露骨描写，保留文学性" }
      ]
    }
  ]
}
